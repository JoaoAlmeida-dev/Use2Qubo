{
  "decision_var_associations": ["RouteRoad", "AssignedTo"],
  "decision_vars": [
    {
      "type": "link",
      "association": "RouteRoad",
      "domain": ["Route", "Road"]
    },
    {
      "type": "link",
      "association": "AssignedTo",
      "domain": ["Route", "Truck"]
    }
  ],
  "objective": {
    "expression": "Route.allInstances->collect(r | r.edgeCost())->sum()",
    "minimise": true,
    "max_degree": 7
  }
}
