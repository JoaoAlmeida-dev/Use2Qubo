{
  "decision_var_associations": [
    "AssignedTo",
    "RouteRoad"
  ],
  "decision_vars": [
{
      "type": "link",
      "association": "AssignedTo",
      "domain": [
        "Route",
        "Truck"
      ]
    },
{
      "type": "link",
      "association": "RouteRoad",
      "domain": [
        "Route",
        "Road"
      ]
    }
  ],
  "objective": {
    "expression": "Route.allInstances->collect(r | r.edgeCost())->sum()",
    "minimise": true,
    "max_degree": 15
  }
}
